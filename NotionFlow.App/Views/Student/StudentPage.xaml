<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NotionFlow.App.Views.Student.StudentPage"
             Title="Mis Cursos">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Label Text="Mis Cursos"
               FontSize="24" FontAttributes="Bold"
               HorizontalOptions="Center" />

        <Button Text="Cerrar Sesión"
                Command="{Binding CerrarSesionCommand}"
                HorizontalOptions="End" />

        <CollectionView ItemsSource="{Binding Cursos}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,5" Padding="15" StrokeThickness="1" Stroke="{StaticResource Gray300}">
                        <VerticalStackLayout>
                            <Label Text="{Binding Nombre}" FontAttributes="Bold" FontSize="16" />
                            <Label Text="{Binding Materia}" FontSize="13" TextColor="{StaticResource Gray400}" />
                            <Label Text="{Binding ProfesorNombre, StringFormat='Profesor: {0}'}"
                                   FontSize="13" TextColor="{StaticResource Gray400}" />
                            <Button Text="Ver curso"
                                    CommandParameter="{Binding .}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IrACursoCommand}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>

</ContentPage>
