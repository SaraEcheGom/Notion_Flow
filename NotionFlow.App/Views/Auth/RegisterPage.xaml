<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NotionFlow.App.Views.Auth.RegisterPage"
             Title="Crear Cuenta">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="15" VerticalOptions="Center">

            <Label Text="Crear Cuenta"
                   FontSize="26" FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <Entry Placeholder="Nombre completo"
                   Text="{Binding Nombre}" />

            <Entry Placeholder="Correo electrónico"
                   Text="{Binding Email}"
                   Keyboard="Email" />

            <Entry Placeholder="Contraseña"
                   Text="{Binding Password}"
                   IsPassword="True" />

            <Label Text="Tipo de cuenta" TextColor="{StaticResource Gray400}" FontSize="13" />

            <Picker Title="Selecciona un rol"
                    ItemsSource="{Binding Roles}"
                    SelectedItem="{Binding RolSeleccionado}" />

            <Entry Placeholder="Token de autorización"
                   Text="{Binding Token}"
                   IsPassword="True"
                   IsVisible="{Binding MostrarToken}" />

            <Label Text="Se requiere token para crear cuentas de Profesor o Admin"
                   TextColor="{StaticResource Gray400}"
                   FontSize="12"
                   IsVisible="{Binding MostrarToken}" />

            <Button Text="Registrarse"
                    Command="{Binding RegisterCommand}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
