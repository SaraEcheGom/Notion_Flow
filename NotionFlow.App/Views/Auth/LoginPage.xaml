<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:NotionFlow.App.ViewModels.Auth"
             x:Class="NotionFlow.App.Views.Auth.LoginPage"
             Title="Login">

    <ContentPage.BindingContext>
        <vm:LoginViewModel />
    </ContentPage.BindingContext>

    <VerticalStackLayout Padding="30" Spacing="15" VerticalOptions="Center">

        <Label Text="NotionFlow"
               FontSize="30"
               HorizontalOptions="Center" />

        <Entry Placeholder="Email"
               Text="{Binding Email}"
               Keyboard="Email" />

        <Entry Placeholder="Contraseña"
               IsPassword="True"
               Text="{Binding Password}" />

        <Button Text="Iniciar Sesión"
                Command="{Binding LoginCommand}" />

        <Button Text="Crear Cuenta"
                Command="{Binding GoRegisterCommand}" />

    </VerticalStackLayout>

</ContentPage>
