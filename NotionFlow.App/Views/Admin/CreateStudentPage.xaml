<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NotionFlow.App.Views.Admin.CreateStudentPage"
             Title="Create Student">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15" VerticalOptions="Center">

            <Label Text="New Student"
                   FontSize="22" FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <Entry Placeholder="Full name"
                   Text="{Binding StudentName}" />

            <Entry Placeholder="Email"
                   Text="{Binding StudentEmail}"
                   Keyboard="Email" />

            <Entry Placeholder="Password"
                   Text="{Binding StudentPassword}"
                   IsPassword="True" />

            <Button Text="Create Student"
                    Command="{Binding CreateStudentCommand}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
