<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NotionFlow.App.Views.PerfilUsuarioPage"
             Title="Perfil">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Frame BackgroundColor="#2d2d2d" CornerRadius="50"
                   HeightRequest="100" WidthRequest="100"
                   HorizontalOptions="Center" Padding="0">
                <Label Text="{Binding Inicial}"
                       FontSize="40" FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Frame>

            <Label Text="{Binding Nombre}"
                   FontSize="22" FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <Label Text="{Binding Rol}"
                   FontSize="14" TextColor="Gray"
                   HorizontalOptions="Center" />

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,10" />

            <Label Text="Correo" FontSize="13" TextColor="Gray" />
            <Label Text="{Binding Email}" FontSize="16" />

            <Label Text="Cursos asignados" FontSize="13"
                   TextColor="Gray" Margin="0,10,0,0" />

            <CollectionView ItemsSource="{Binding Cursos}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,4" Padding="12"
                                StrokeThickness="1" Stroke="LightGray"
                                StrokeShape="RoundRectangle 8">
                            <VerticalStackLayout>
                                <Label Text="{Binding Nombre}"
                                       FontAttributes="Bold" />
                                <Label Text="{Binding Materia}"
                                       FontSize="13" TextColor="Gray" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>