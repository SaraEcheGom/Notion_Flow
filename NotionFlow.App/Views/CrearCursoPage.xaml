<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NotionFlow.App.Views.CrearCursoPage"
             Title="Crear Curso">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="Nuevo Curso"
                   FontSize="22" FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <Entry Placeholder="Nombre del curso"
                   Text="{Binding NombreCurso}" />

            <Entry Placeholder="Materia"
                   Text="{Binding MateriaCurso}" />

            <Label Text="Selecciona Profesor" TextColor="Gray" FontSize="13" />

            <Picker Title="Profesor"
                    ItemsSource="{Binding Profesores}"
                    ItemDisplayBinding="{Binding Nombre}"
                    SelectedItem="{Binding ProfesorSeleccionado}" />

            <Button Text="Crear Curso"
                    Command="{Binding CrearCursoCommand}" />

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,10" />

            <Label Text="Asignar Estudiante a Curso"
                   FontSize="18" FontAttributes="Bold" />

            <Picker Title="Estudiante"
                    ItemsSource="{Binding Estudiantes}"
                    ItemDisplayBinding="{Binding Nombre}"
                    SelectedItem="{Binding EstudianteSeleccionado}" />

            <Picker Title="Curso"
                    ItemsSource="{Binding Cursos}"
                    ItemDisplayBinding="{Binding Nombre}"
                    SelectedItem="{Binding CursoSeleccionado}" />

            <Button Text="Asignar Estudiante"
                    Command="{Binding AsignarEstudianteCommand}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>