<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NotionFlow.App.Views.Teacher.PublishContentPage"
             Title="Publish Content">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15" VerticalOptions="Center">

            <Label Text="New Content"
                   FontSize="22" FontAttributes="Bold"
                   HorizontalOptions="Center" />

            <Label Text="Title"
                   FontSize="14" FontAttributes="Bold" />
            <Entry x:Name="TitleEntry"
                   Placeholder="Content title"
                   Keyboard="Default" />

            <Label Text="Description"
                   FontSize="14" FontAttributes="Bold" />
            <Editor x:Name="DescriptionEntry"
                    Placeholder="Content description"
                    HeightRequest="100" />

            <Label Text="Content Type"
                   FontSize="14" FontAttributes="Bold" />
            <Picker x:Name="TypePicker"
                    Title="Select content type">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>Video</x:String>
                        <x:String>Document</x:String>
                        <x:String>Image</x:String>
                        <x:String>Link</x:String>
                        <x:String>Other</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>

            <Label Text="URL or Path"
                   FontSize="14" FontAttributes="Bold" />
            <Entry x:Name="UrlEntry"
                   Placeholder="https://example.com/resource"
                   Keyboard="Url" />

            <Button Text="Publish Content"
                    Clicked="OnPublish"
                    Margin="0,20,0,0" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
