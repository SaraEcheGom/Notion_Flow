<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NotionFlow.App.Views.Professor.CreateEvaluationPage"
             Title="Nueva Evaluación">

    <VerticalStackLayout Padding="20" Spacing="15" VerticalOptions="Center">

        <Entry Placeholder="Título" x:Name="TitleEntry" />
        <Entry Placeholder="Descripción" x:Name="DescriptionEntry" />
        <Entry Placeholder="Porcentaje (ej: 20)"
               x:Name="PercentageEntry" Keyboard="Numeric" />
        <Button Text="Guardar" Clicked="OnSave" />

    </VerticalStackLayout>

</ContentPage>
